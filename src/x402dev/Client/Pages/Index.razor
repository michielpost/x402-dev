@page "/"

<PageTitle>x402dev - Home</PageTitle>

<div class="home-hero">
    <div class="home-hero-inner">
        <div class="home-hero-badge">x402 Protocol</div>
        <h1 class="home-hero-title">Developer Tools for the<br /><span class="home-hero-accent">x402 Ecosystem</span></h1>
        <p class="home-hero-desc">Test integrations, monitor facilitators, post payments, and discover x402-powered projects, all in one place.</p>
        <div class="home-hero-actions">
            <FluentAnchor Appearance="Appearance.Accent" Href="/resource-tester">Start Testing</FluentAnchor>
            <a href="https://x402.org" target="_blank" rel="noopener" class="home-outline-btn">Learn x402 →</a>
        </div>
    </div>
</div>

<div class="home-section">
    <h2 class="home-section-title">Explore the Tools</h2>
    <p class="home-section-desc">Everything you need to build, test, and discover x402-powered experiences.</p>
    <div class="feature-grid">
        <a href="/facilitators" class="feature-card">
            <div class="feature-card-icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.People())" Color="Color.Accent" />
            </div>
            <h3 class="feature-card-title">Facilitators</h3>
            <p class="feature-card-desc">Monitor active x402 facilitators, their live status, and supported networks.</p>
        </a>
        <a href="/messages" class="feature-card">
            <div class="feature-card-icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.Chat())" Color="Color.Accent" />
            </div>
            <h3 class="feature-card-title">Messages</h3>
            <p class="feature-card-desc">Browse and post public messages backed by x402 payments.</p>
        </a>
        <a href="/resource-tester" class="feature-card">
            <div class="feature-card-icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.AppsListDetail())" Color="Color.Accent" />
            </div>
            <h3 class="feature-card-title">Resource Tester</h3>
            <p class="feature-card-desc">Send requests to x402-protected endpoints and inspect payment headers and responses.</p>
        </a>
        <a href="/signature-builder" class="feature-card">
            <div class="feature-card-icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.DocumentSignature())" Color="Color.Accent" />
            </div>
            <h3 class="feature-card-title">Signature Builder</h3>
            <p class="feature-card-desc">Construct and validate custom x402 payment signatures for authentication flows.</p>
        </a>
        <a href="/base64-helper" class="feature-card">
            <div class="feature-card-icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.Code())" Color="Color.Accent" />
            </div>
            <h3 class="feature-card-title">Base64 Helper</h3>
            <p class="feature-card-desc">Encode and decode Base64 strings used inside x402 payment and authorization headers.</p>
        </a>
        <a href="/awesome-projects" class="feature-card">
            <div class="feature-card-icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.Star())" Color="Color.Accent" />
            </div>
            <h3 class="feature-card-title">Awesome Projects</h3>
            <p class="feature-card-desc">Discover innovative applications and services built on the x402 payment protocol.</p>
        </a>
    </div>
</div>

<div class="home-section">
    <h2 class="home-section-title">Recent Messages</h2>
    <p class="home-section-desc">Latest messages posted using x402 payments on Base.</p>
    <MessagesList />
</div>

