@page "/awesome-projects"

<PageTitle>x402dev - Awesome x402 Projects</PageTitle>

<div class="page-header">
    <span class="page-eyebrow">Community</span>
    <h1>Awesome Projects</h1>
    <p class="page-desc">
        Discover innovative applications, tools, and services built on the x402 payment protocol —
        curated by the community.
    </p>
    <div class="page-header-actions">
        <FluentAnchor Appearance="Appearance.Accent"
                      Href="https://github.com/michielpost/x402-dev/blob/master/Projects.md"
                      Target="_blank"
                      Rel="noopener">
            View on GitHub
        </FluentAnchor>
    </div>
</div>

@if (Text == null)
{
    <div class="page-loading">
        <FluentProgressRing />
        <span>Loading projects…</span>
    </div>
}
else
{
    <div class="md-content">
        @(Text)
    </div>
}

<FluentCard Class="page-cta-card" Style="padding: 0; overflow: hidden;">
    <div class="page-cta-inner">
        <div>
            <h3>Want to add your project?</h3>
            <p>Built something with x402? Share it with the community by submitting a pull request.</p>
        </div>
        <FluentAnchor Appearance="Appearance.Accent"
                      Href="https://github.com/michielpost/x402-dev/blob/master/Projects.md"
                      Target="_blank"
                      Rel="noopener">
            Submit a Pull Request
        </FluentAnchor>
    </div>
</FluentCard>

@code {
    MarkupString? Text = null;

    protected override void OnInitialized()
    {
        using var stream = typeof(AwesomeProjects).Assembly.GetManifestResourceStream("projects.md");
        if (stream != null)
        {
            using var reader = new StreamReader(stream);
            var html = Markdig.Markdown.ToHtml(reader.ReadToEnd());
            Text = (MarkupString)html;
        }
    }
}
